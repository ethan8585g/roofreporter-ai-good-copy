# RoofManager Debug Scan — environment variables
# Copy to .env and fill in real values before running.

# ── Cloudflare D1 (required for all DB checks) ───────────────────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-d1-read-only-api-token
D1_DATABASE_ID=e64c0cf3-43fa-4f41-ac75-ed12694a26c5   # roofing-production

# ── Target environment ────────────────────────────────────────────────────────
API_BASE_URL=https://www.roofmanager.ca

# ── Optional: local log file path (leave blank to skip) ──────────────────────
LOG_PATH=
# LOG_PATH=/var/log/roofmanager/error.log
