{
  "name": "roofing-measurement-tool",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "audit:links": "node scripts/audit-internal-links.mjs",
    "prebuild": "node scripts/audit-internal-links.mjs",
    "build": "node build.mjs",
    "build:vite": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name roofing-measurement-tool",
    "deploy:cron": "wrangler deploy --config wrangler-cron.jsonc",
    "dev:sandbox": "wrangler pages dev dist --d1=roofing-production --local --ip 0.0.0.0 --port 3000",
    "db:migrate:local": "wrangler d1 migrations apply roofing-production --local",
    "db:seed": "wrangler d1 execute roofing-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console:local": "wrangler d1 execute roofing-production --local",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/push-notifications": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "better-sqlite3": "^12.8.0",
    "geotiff": "^3.0.3",
    "geotiff-geokeys-to-proj4": "^2024.4.13",
    "hono": "^4.11.9",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.0",
    "proj4": "^2.20.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/forms": "^0.5.11",
    "@types/proj4": "^2.5.6",
    "marked": "^18.0.2",
    "tailwindcss": "^4.2.2",
    "vite": "^6.3.5",
    "vitest": "^4.0.18",
    "wrangler": "^4.4.0"
  }
}
